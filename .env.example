# ── Database ─────────────────────────────────────────────────────────────────
# Direct connection (no -pooler) required for prisma db push / migrate
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers ───────────────────────────────────────────────────────────
# Google — https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub — https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Email (optional — logs to console if not set) ─────────────────────────────
# Leave blank to use console output (fine for development)
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# ── Legacy (no longer used — kept for reference) ──────────────────────────────
# JWT_SECRET was replaced by AUTH_SECRET above
